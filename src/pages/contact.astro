---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Kontakt - Alchemia Września">
	<section class="min-h-[70vh] flex items-center">
		<div class="container mx-auto px-4">
			<div class="max-w-5xl mx-auto">

				<div>
					<h1>KONTAKT</h1>
					<p class="uppercase tracking-widest w-fit border-b-2 border-gray-400 pb-2 mb-6">Sportowy Klub Taneczny "Alchemia Września"</p>
				</div>

				<div class="grid lg:grid-cols-2 gap-12 items-start">

					<div class="flex flex-col justify-between gap-12 py-2">
						<div class="flex items-start gap-4">
							<div class="bg-primary/10 p-3 rounded-lg">
								<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
							</div>
							<div>
								<h3>Adres</h3>
								<p>ul. 68 Pułku Piechoty 4, 62-300 WRZEŚNIA</p>
							</div>
						</div>

						<div class="flex items-start gap-4">
							<div class="bg-primary/10 p-3 rounded-lg">
								<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
							</div>
							<div>
								<h3>Napisz do nas</h3>
								<a href="mailto:swidurska.k@wp.pl" class="link no-underline hover:underline">swidurska.k@wp.pl</a>
							</div>
						</div>

						<div class="flex items-start gap-4">
							<div class="bg-primary/10 p-3 rounded-lg">
								<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
							</div>
							<div>
								<h3>Zadzwoń</h3>
								<a href="tel:+48728491623" class="link no-underline hover:underline">+48 728 491 623</a>
							</div>
						</div>
					</div>

					<div class="relative group h-full">
						<div class="absolute -inset-2 rounded-2xl blur-xl opacity-50 transition group-hover:opacity-100"></div>
						<div class="relative bg-white p-3 rounded-xl shadow-xl overflow-hidden border border-gray-100">
							<iframe
									src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2440.06126600889!2d17.562380877202353!3d52.33120647201202!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x4704e973d8cfe525%3A0xd11fd1e4dd8ef873!2sAlchemy%20Dance%20Studio-school%20dance!5e0!3m2!1spl!2spl!4v1710000000000!5m2!1spl!2spl"
									class="w-full h-full min-h-[350px] rounded-xl border-0"
									allowfullscreen=""
									loading="lazy"
									referrerpolicy="no-referrer-when-downgrade">
							</iframe>
						</div>
					</div>

				</div>
			</div>
		</div>
	</section>
</Layout>